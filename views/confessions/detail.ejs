<%- include('../partials/layout', {
  title: 'Ispovijest',
  body: `
    <div class="card p-4">
      <h2>Ispovijest #${confession.id}</h2>
      <p>${escape(confession.text)}</p>
      <div class="d-flex align-items-center gap-2 mb-2">
        <small class="text-muted">${new Date(confession.created_at).toLocaleString()}</small>
        <span class="badge ${confession.status === 'published' ? 'bg-success' : 'bg-secondary'} status-badge" data-id="${confession.id}">
          ${confession.status}
        </span>
      </div>

      <div class="mt-2 d-flex gap-2 align-items-center">

        <!-- 👍 Like: SVI (gosti i korisnici) -->
        <button type="button" class="btn btn-sm btn-outline-primary like-btn" data-id="${confession.id}">
          👍 <span class="like-count" id="like-count-${confession.id}" data-id="${confession.id}">
            ${confession.like_count || 0}
          </span>
        </button>

        <!-- ⭐ Broj favorita (read-only) -->
        <small class="text-muted">⭐ ${confession.favorite_count || 0}</small>

        <!-- ⭐ Dodaj u favorite: samo prijavljeni -->
        ${currentUser
          ? `<form method="POST" action="/confessions/${confession.id}/favorite" style="display:inline;">
               <button class="btn btn-sm btn-outline-warning">Favorit</button>
             </form>`
          : `` }

        <!-- ✅ Approve: dozvoljeno i gostima -->
        <button type="button" class="btn btn-sm btn-success approve-btn" data-id="${confession.id}">
          Odobri
        </button>
      </div>
    </div>

    <hr/>
    <h4>Komentari</h4>
    ${comments && comments.length > 0
      ? `<ul class="list-group">
          ${comments.map(c => `
            <li class="list-group-item">
              <p>${escape(c.content)}</p>
              <small class="text-muted">
                Od: ${c.email ? escape(c.email) : 'Gost'} | ${new Date(c.created_at).toLocaleString()}
              </small>
            </li>
          `).join('')}
        </ul>`
      : `<p class="text-muted">Nema komentara.</p>` }

    <!-- ✍️ Forma za komentar: SVI (gosti i korisnici) -->
    <form method="POST" action="/confessions/${confession.id}/comment" class="mt-3">
      <div class="mb-3">
        <textarea name="content" class="form-control" rows="2" placeholder="Napišite komentar..." required></textarea>
      </div>
      <div class="d-flex align-items-center gap-2">
        <button class="btn btn-primary btn-sm">Dodaj komentar</button>
        ${!currentUser ? `<small class="text-muted">Komentar će biti objavljen kao <strong>Gost</strong>.</small>` : ``}
      </div>
    </form>
  `
}) %>
