<%- include('partials/layout', { title: title, body: `
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card p-4">
        <h2 class="mb-3">Odobravanje ispovijesti</h2>

        ${!confession
          ? `<div class="alert alert-success">Nema više ispovijesti za odobravanje. 🎉</div>`
          : `
            <div class="mb-3">
              <p class="fs-5">${escape(confession.text)}</p>
              <small class="text-muted">Kreirano: ${new Date(confession.created_at).toLocaleString()}</small>
            </div>

            <div class="d-flex gap-2">
              <form method="POST" action="/approve/${confession.id}/yes">
                <button class="btn btn-success">Odobri</button>
              </form>
              <form method="POST" action="/approve/${confession.id}/skip">
                <button class="btn btn-outline-secondary">Preskoči</button>
              </form>
            </div>
          `
        }
      </div>
    </div>
  </div>
` }) %>
