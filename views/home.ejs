<%- include('partials/layout', { title: 'Početna', body: `
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card p-4">
        <h2 class="mb-3">Početna</h2>

        ${currentUser
          ? `<div class="alert alert-success">Prijavljeni ste kao <strong>${escape(currentUser.email)}</strong>.</div>`
          : `<div class="alert alert-info">Pregledavate kao <strong>Gost</strong>. 
               <a href="/auth/login">Prijava</a> ili 
               <a href="/auth/register">Registracija</a>.</div>` }

        <ul class="nav nav-tabs mb-3">
          <li class="nav-item">
            <a class="nav-link ${activeTab === 'popular' ? 'active' : ''}" href="/feed/popular">Popularne</a>
          </li>
          <li class="nav-item">
            <a class="nav-link ${activeTab === 'best' ? 'active' : ''}" href="/feed/best">Najbolje</a>
          </li>
          <li class="nav-item">
            <a class="nav-link ${activeTab === 'latest' ? 'active' : ''}" href="/feed/latest">Najnovije</a>
          </li>
          <li class="nav-item">
            <a class="nav-link ${activeTab === 'random' ? 'active' : ''}" href="/feed/random">Random</a>
          </li>
        </ul>

        ${confessions && confessions.length > 0
          ? `<div class="list-group mb-3">
               ${confessions.map(c => `
                 <div class="list-group-item">
                   <p>${escape(c.text)}</p>
                   <div class="d-flex align-items-center gap-2">

                     <!-- 👍 Like dugme -->
                     <button class="btn btn-sm btn-outline-primary like-btn" data-id="${c.id}">
                       👍 <span class="like-count" id="like-count-${c.id}" data-id="${c.id}">
                         ${Number(c.like_count || 0)}
                       </span>
                     </button>

                     <!-- 💬 i ⭐ -->
                     <small class="text-muted">💬 ${Number(c.comment_count || 0)}</small>
                     <small class="text-muted">⭐ ${Number(c.favorite_count || 0)}</small>

                     <!-- 🏷️ Status: feed pokazuje samo objavljene -->
                     <span class="badge bg-success ms-2 status-badge" data-id="${c.id}">
                       published
                     </span>

                     <!-- ⭐ Favorit (klasičan POST) -->
                     ${currentUser
                       ? `<form method="POST" action="/confessions/${c.id}/favorite" style="display:inline;">
                            <button class="btn btn-sm btn-outline-warning">Favorit</button>
                          </form>`
                       : `` }

                     <!-- 🔗 Komentari link -->
                     <a href="/confessions/${c.id}" class="btn btn-sm btn-outline-secondary">Komentari</a>

                   </div>
                 </div>
               `).join('')}
             </div>`
          : `<p class="text-muted">Nema ispovijesti za prikaz.</p>` }

        <hr/>
        <h4>Dodaj novu ispovijest</h4>
        <form method="POST" action="/confessions/new" class="card p-3">
          <div class="mb-3">
            <textarea name="text" class="form-control" rows="3" placeholder="Napišite anonimnu ispovijest..." required></textarea>
          </div>
          <button class="btn btn-primary">Objavi</button>
        </form>
      </div>
    </div>
  </div>
` }) %>
