<!DOCTYPE html>
<html lang="bs">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title || 'Ispovijesti' %></title>

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Tvoj custom CSS -->
  <link href="/css/styles.css" rel="stylesheet">
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
  <div class="container">
    <a class="navbar-brand" href="/home">Ispovijesti</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain" aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarMain">
      <ul class="navbar-nav ms-auto">

        <% if (currentUser) { %>
          <!-- Vidljivo SVIMA: Odobravaj -->
          <li class="nav-item">
            <a class="nav-link" href="/approve">Odobri</a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/confessions/new">Nova ispovijest</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/favorites">Moji favoriti</a>
          </li>
          <li class="nav-item">
            <a class="nav-link d-flex align-items-center" href="/notifications">
              Notifikacije
              <% if (typeof unreadNotifCount !== 'undefined' && unreadNotifCount > 0) { %>
                <span class="badge bg-danger ms-1"><%= unreadNotifCount > 99 ? '99+' : unreadNotifCount %></span>
              <% } %>
            </a>
          </li>

          <% if (currentUser.role === 'admin') { %>
            <li class="nav-item">
              <a class="nav-link" href="/admin/confessions">Admin panel</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/admin/users">Korisnici</a>
            </li>
          <% } %>

          <!-- Odjava kao nav-item, poravnata vertikalno s linkovima -->
          <li class="nav-item d-flex align-items-center">
            <form action="/auth/logout" method="POST" class="m-0">
              <button class="btn btn-outline-light btn-sm ms-lg-2">Odjava</button>
            </form>
          </li>

        <% } else { %>
          <!-- Vidljivo SVIMA: Odobravaj (gosti imaju weight=1) -->
          <li class="nav-item">
            <a class="nav-link" href="/approve">Odobri</a>
          </li>

          <li class="nav-item">
            <a class="btn btn-outline-light btn-sm me-2" href="/auth/login">Prijava</a>
          </li>
          <li class="nav-item">
            <a class="btn btn-primary btn-sm" href="/auth/register">Registracija</a>
          </li>
        <% } %>

      </ul>
    </div>
  </div>
</nav>

<main class="container py-4">
  <%- body %>
</main>

<!-- Bootstrap Bundle with Popper -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<!-- Tvoj JS -->
<script src="/js/main.js"></script>
</body>
</html>
