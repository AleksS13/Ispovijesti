<!DOCTYPE html>
<html lang="bs">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title || 'Ispovijesti' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/styles.css" rel="stylesheet">
</head>
<body>
<nav class="navbar navbar-expand-lg bg-dark navbar-dark">
  <div class="container">
    <a class="navbar-brand" href="/">Ispovijesti</a>
    <div class="ms-auto">
      <% if (currentUser) { %>
        <form action="/auth/logout" method="POST" class="d-inline">
          <button class="btn btn-outline-light btn-sm">Odjava</button>
        </form>
      <% } else { %>
        <a class="btn btn-outline-light btn-sm" href="/auth/login">Prijava</a>
        <a class="btn btn-primary btn-sm ms-2" href="/auth/register">Registracija</a>
      <% } %>
    </div>
  </div>
</nav>

<main class="container py-4">
  <%- body %>
</main>

</body>
</html>
