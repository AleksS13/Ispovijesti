<h2 class="mb-3">Notifikacije</h2>

<% if (notifications.length === 0) { %>
  <div class="alert alert-info">Nema notifikacija.</div>
<% } else { %>
  <ul class="list-group mb-3">
    <% notifications.forEach(n => { %>
      <li class="list-group-item d-flex justify-content-between align-items-start">
        <div>
          <p class="mb-1">
            <% if (n.type === 'comment_on_favorite') { %>
              Novi komentar na tvojoj omiljenoj ispovijesti
            <% } else { %>
              <%= n.type %>
            <% } %>
          </p>
          <% if (n.payload && n.payload.snippet) { %>
            <small class="text-muted">"<%= n.payload.snippet %>"</small><br>
          <% } %>
          <small class="text-muted">
            <%= new Date(n.created_at).toLocaleString('bs-BA') %>
          </small>
        </div>
        <div>
          <% if (!n.is_read) { %>
            <form action="/notifications/<%= n.id %>/read" method="POST" class="d-inline">
              <button class="btn btn-sm btn-success">Označi pročitano</button>
            </form>
          <% } %>
        </div>
      </li>
    <% }) %>
  </ul>

  <form action="/notifications/read-all" method="POST">
    <button class="btn btn-outline-primary">Označi sve kao pročitano</button>
  </form>
<% } %>
