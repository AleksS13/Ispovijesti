<h2 class="mb-3">Admin – Ispovijesti (<%= activeStatus %>)</h2>

<ul class="nav nav-tabs mb-3">
  <li class="nav-item">
    <a class="nav-link <%= activeStatus === 'waiting' ? 'active' : '' %>"
       href="/admin/confessions?status=waiting">Na čekanju</a>
  </li>
  <li class="nav-item">
    <a class="nav-link <%= activeStatus === 'rejected_ai' ? 'active' : '' %>"
       href="/admin/confessions?status=rejected_ai">AI odbijene</a>
  </li>
  <li class="nav-item">
    <a class="nav-link <%= activeStatus === 'rejected' ? 'active' : '' %>"
       href="/admin/confessions?status=rejected">Odbijene</a>
  </li>
  <li class="nav-item">
    <a class="nav-link <%= activeStatus === 'published' ? 'active' : '' %>"
       href="/admin/confessions?status=published">Objavljene</a>
  </li>
</ul>

<% if (confessions.length === 0) { %>
  <div class="alert alert-info">Nema ispovijesti u ovoj kategoriji.</div>
<% } else { %>
  <ul class="list-group">
    <% confessions.forEach(c => { %>
      <li class="list-group-item">
        <div><strong>#<%= c.id %></strong> – <%= escape(c.text) %></div>
        <small class="text-muted"><%= new Date(c.created_at).toLocaleString() %></small>
        <div class="mt-2">
          <form method="POST" action="/admin/confessions/<%= c.id %>/publish" class="d-inline">
            <button class="btn btn-sm btn-success">Objavi</button>
          </form>
          <form method="POST" action="/admin/confessions/<%= c.id %>/reject" class="d-inline">
            <button class="btn btn-sm btn-warning">Odbij</button>
          </form>
          <form method="POST" action="/admin/confessions/<%= c.id %>/delete" class="d-inline">
            <button class="btn btn-sm btn-danger">Obriši</button>
          </form>
        </div>
      </li>
    <% }) %>
  </ul>

  <nav class="mt-3">
    <ul class="pagination mb-0">
      <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
        <a class="page-link" href="/admin/confessions?status=<%= activeStatus %>&page=<%= page-1 %>&limit=<%= limit %>">Prethodna</a>
      </li>
      <li class="page-item disabled">
        <span class="page-link">Strana <%= page %> / <%= totalPages %></span>
      </li>
      <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>">
        <a class="page-link" href="/admin/confessions?status=<%= activeStatus %>&page=<%= page+1 %>&limit=<%= limit %>">Sljedeća</a>
      </li>
    </ul>
    <small class="text-muted">Ukupno: <%= total %></small>
  </nav>
<% } %>
