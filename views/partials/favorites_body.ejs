<h2 class="mb-3">Moji favoriti</h2>

<% if (confessions.length === 0) { %>
  <div class="alert alert-info">Još nemaš nijednu ispovijest u favoritima.</div>
<% } else { %>
  <div class="list-group">
    <% confessions.forEach(c => { %>
      <div class="list-group-item">
        <p class="mb-1"><%= c.text %></p>
        <small class="text-muted">
          ❤️ <%= c.like_count %> | 💬 <%= c.comment_count %> | Dodano: 
          <%= new Date(c.fav_since).toLocaleString('bs-BA') %>
        </small>
        <div class="mt-2">
          <form action="/confessions/<%= c.id %>/unfavorite" method="POST" class="d-inline">
            <button class="btn btn-sm btn-outline-danger">Ukloni</button>
          </form>
          <a href="/confessions/<%= c.id %>" class="btn btn-sm btn-outline-primary">Detalji</a>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>
